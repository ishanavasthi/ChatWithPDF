{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": ["**/.env"],
    "ui": "tui",
    "tasks": {
      "dev": {
        "cache": false,
        "interactive": true
      },
      "build": {
        "dependsOn": ["^build"],
        "outputs": ["**/dist/**"]
      },
      "lint": {
        "dependsOn": ["^lint"]
      },
      "format": {
        "dependsOn": ["^format"]
      }
    }
  }